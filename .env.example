# =========================================================
# Tasknest — Example environment variables
# Copy to .env (local dev) or .env.prod (production)
# Never commit .env or .env.prod
# =========================================================

# --- Node / runtime ---
NODE_ENV=development
TZ=Europe/Paris

# --- API ---
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:3000

# --- PostgreSQL ---
POSTGRES_USER=tasknest
POSTGRES_PASSWORD=changeme_dev
POSTGRES_DB=tasknest_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://tasknest:changeme_dev@postgres:5432/tasknest_dev?schema=public

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# --- Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))") ---
TASKNEST_DB_ENCRYPTION_KEY=
AUTH_SECRET=
JWT_SECRET=

# --- Better Auth ---
AUTH_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:4000

# --- OAuth Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OAuth Microsoft ---
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# --- OAuth Apple ---
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- SMTP (dev = Mailpit, prod = your provider) ---
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@tasknest.local

# --- Object storage (attachments, exports) ---
S3_ENDPOINT=http://minio:9000
S3_REGION=auto
S3_BUCKET=tasknest
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Expo Push (mobile notifs) ---
EXPO_ACCESS_TOKEN=

# --- Web Push VAPID ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tasknest.local

# --- Monitoring (optional) ---
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# --- Feature flags ---
FEATURE_DEMO_MODE=true
FEATURE_OPEN_REGISTRATION=true

# --- Production deployment (docker-compose.prod.yml) ---
# Top-level domain used by Traefik (Host rules)
DOMAIN=tasknest.example.org
# Let's Encrypt ACME contact e-mail (operator's own — never commit a real
# address; this file is an example only)
ACME_EMAIL=admin@tasknest.example.org
# Image tag to pull (defaults to "latest")
TASKNEST_VERSION=latest
