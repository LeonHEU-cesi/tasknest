{
  "name": "@tasknest/web",
  "version": "0.1.0",
  "private": true,
  "description": "Tasknest web frontend (Next.js + PWA)",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "test": "vitest run",
