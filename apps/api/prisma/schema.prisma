generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// US-AU-01..07 — Schéma aligné sur Better Auth (système d'auth complet).
// Pourquoi ce remodelage vs Sprint 1 : Better Auth possède désormais
// user/session/account/verification. Les anciennes tables custom
// (email_verifications, password_resets, sessions hand-rolled) sont
// remplacées par les flux natifs Better Auth (Verification + Account).
// Projet pré-alpha sans données de production : migration destructive assumée.

model User {
  id            String  @id @default(uuid()) @db.Uuid
  // `name` = nom affiché (ex-`displayName` du Sprint 1, 1–80 caractères)
  name          String  @db.VarChar(80)
  email         String  @unique @db.VarChar(254)
  emailVerified Boolean @default(false) @map("email_verified")
  // `image` = URL d'avatar (ex-`avatarUrl` du Sprint 1)
  image         String? @map("image")

  // Champs applicatifs (Better Auth `additionalFields`)
  locale      String    @default("fr") @db.VarChar(8)
  timezone    String    @default("Europe/Paris") @db.VarChar(64)
  isAdmin     Boolean   @default(false) @map("is_admin")
  suspendedAt DateTime? @map("suspended_at")
  deletedAt   DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions Session[]
  accounts Account[]

  @@index([deletedAt])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  // Token de session opaque (Better Auth le hash/gère côté lib)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address") @db.Inet
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Account {
  id         String @id @default(uuid()) @db.Uuid
  // Identifiant du compte chez le provider (sub OAuth, ou userId pour credential)
  accountId  String @map("account_id")
  // "credential" pour email/mot de passe, "google"/"microsoft"/"apple" pour OAuth
  providerId String @map("provider_id") @db.VarChar(32)
  userId     String @map("user_id") @db.Uuid

  // Hash du mot de passe (provider "credential" uniquement)
  password String? @db.VarChar(255)

  // Tokens OAuth — stockés CHIFFRÉS (libsodium secretbox, cf. US-AU-05/#15).
  // Le texte clair ne transite jamais en base : chiffrement appliqué via
  // les hooks Better Auth avant persistance.
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  // identifier = e-mail (vérification) ou clé du flux (reset, etc.)
  identifier String   @db.VarChar(254)
  // value = token (Better Auth gère sa génération/expiration)
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}
