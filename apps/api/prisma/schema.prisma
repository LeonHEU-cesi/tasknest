generator client {
  provider        = "prisma-client-js"
  // US-TA-08 — extension Postgres pg_trgm gérée par Prisma.
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

// US-AU-01..07 — Schéma aligné sur Better Auth (système d'auth complet).
// Pourquoi ce remodelage vs Sprint 1 : Better Auth possède désormais
// user/session/account/verification. Les anciennes tables custom
// (email_verifications, password_resets, sessions hand-rolled) sont
// remplacées par les flux natifs Better Auth (Verification + Account).
// Projet pré-alpha sans données de production : migration destructive assumée.

model User {
  id            String  @id @default(uuid()) @db.Uuid
  // `name` = nom affiché (ex-`displayName` du Sprint 1, 1–80 caractères)
  name          String  @db.VarChar(80)
  email         String  @unique @db.VarChar(254)
  emailVerified Boolean @default(false) @map("email_verified")
  // `image` = URL d'avatar (ex-`avatarUrl` du Sprint 1)
  image         String? @map("image")

  // Champs applicatifs (Better Auth `additionalFields`)
  locale      String    @default("fr") @db.VarChar(8)
  timezone    String    @default("Europe/Paris") @db.VarChar(64)
  isAdmin     Boolean   @default(false) @map("is_admin")
  suspendedAt DateTime? @map("suspended_at")
  deletedAt   DateTime? @map("deleted_at")

  // US-SEC-01 — 2FA TOTP (géré par le plugin Better Auth two-factor).
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")
  // US-ST-03 — auto-complétion du parent quand toutes les sous-tâches done.
  autoCompleteSubtasks Boolean @default(true) @map("auto_complete_subtasks")
  // US-NO-06 / US-US-03 — préférences notifications (canaux + types).
  notifyReminders Boolean @default(true) @map("notify_reminders")
  notifyDigest    Boolean @default(true) @map("notify_digest")
  notifyWebPush   Boolean @default(true) @map("notify_web_push")
  notifyEmail     Boolean @default(true) @map("notify_email")

  // US-SY-11 — jeton du flux .ics d'abonnement (URL publique read-only,
  // non devinable, rotable). Null = pas de flux actif.
  icsFeedToken String? @unique @map("ics_feed_token")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions   Session[]
  accounts   Account[]
  twoFactors TwoFactor[]
  projects      Project[]
  lists         List[]
  tasks           Task[]           @relation("TaskOwner")
  assignedTasks   Task[]           @relation("TaskAssignee")
  tags              Tag[]
  recurrenceRules   RecurrenceRule[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  calendarAccounts  CalendarAccount[]
  sharesInvited     ProjectShare[]     @relation("ShareInvitedBy")
  sharesMember      ProjectShare[]     @relation("ShareMember")

  @@index([deletedAt])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  // Token de session opaque (Better Auth le hash/gère côté lib)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address") @db.Inet
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Account {
  id         String @id @default(uuid()) @db.Uuid
  // Identifiant du compte chez le provider (sub OAuth, ou userId pour credential)
  accountId  String @map("account_id")
  // "credential" pour email/mot de passe, "google"/"microsoft"/"apple" pour OAuth
  providerId String @map("provider_id") @db.VarChar(32)
  userId     String @map("user_id") @db.Uuid

  // Hash du mot de passe (provider "credential" uniquement)
  password String? @db.VarChar(255)

  // Tokens OAuth — stockés CHIFFRÉS (libsodium secretbox, cf. US-AU-05/#15).
  // Le texte clair ne transite jamais en base : chiffrement appliqué via
  // les hooks Better Auth avant persistance.
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  // identifier = e-mail (vérification) ou clé du flux (reset, etc.)
  identifier String   @db.VarChar(254)
  // value = token (Better Auth gère sa génération/expiration)
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

// US-SEC-01 — Secret TOTP + codes de récupération (1 par utilisateur,
// schéma attendu par le plugin Better Auth two-factor). `secret` et
// `backupCodes` sont gérés/chiffrés par le plugin.
model TwoFactor {
  id          String  @id @default(uuid()) @db.Uuid
  secret      String
  backupCodes String  @map("backup_codes")
  userId      String  @map("user_id") @db.Uuid
  // Géré par le plugin : false tant que le 1er code TOTP n'a pas confirmé.
  verified    Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("two_factors")
}

// US-PR-01 — Projets : conteneur de listes, scoping par propriétaire.
// Suppression = soft-delete (archivedAt), purge effective via job +30j.
model Project {
  id          String    @id @default(uuid()) @db.Uuid
  ownerId     String    @map("owner_id") @db.Uuid
  name        String    @db.VarChar(120)
  description String?
  icon        String?   @db.VarChar(32)
  color       String?   @db.VarChar(7)
  position    Int       @default(0)
  archivedAt  DateTime? @map("archived_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  owner  User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  lists  List[]
  shares ProjectShare[]

  @@index([ownerId])
  @@index([ownerId, archivedAt])
  @@map("projects")
}

// US-SH-01..04 — Partage d'un projet avec un autre compte. L'accès effectif
// d'un utilisateur à un projet (et ses listes/tâches) = propriétaire OU
// `ProjectShare` accepté (rôle viewer/editor). Le filtrage par accès est
// appliqué au niveau applicatif (AccessService) — cohérent avec tout le
// codebase (pas de RLS Postgres). `invitedEmail` = cible de l'invitation ;
// `userId` est lié au compte à l'acceptation (peut différer si l'e-mail
// invité n'est pas l'e-mail du compte qui accepte).
model ProjectShare {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @map("project_id") @db.Uuid
  invitedEmail String    @map("invited_email") @db.VarChar(254)
  // 'viewer' | 'editor'
  role         String    @default("viewer") @db.VarChar(16)
  // 'pending' | 'accepted' | 'declined' | 'revoked'
  status       String    @default("pending") @db.VarChar(16)
  token        String    @unique
  invitedById  String    @map("invited_by_id") @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  expiresAt    DateTime  @map("expires_at")
  acceptedAt   DateTime? @map("accepted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invitedBy User    @relation("ShareInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  user      User?   @relation("ShareMember", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([projectId, invitedEmail])
  @@index([userId, status])
  @@index([projectId, status])
  @@map("project_shares")
}

// US-LI-01 — Listes dans un projet.
model List {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  ownerId     String    @map("owner_id") @db.Uuid
  name        String    @db.VarChar(120)
  description String?
  // 'list' | 'kanban' | 'calendar' | 'timeline'
  viewDefault String    @default("list") @map("view_default") @db.VarChar(16)
  // US-VW-04 — colonnes Kanban personnalisables (statuts ordonnés) par liste.
  kanbanColumns String[] @default(["todo", "doing", "done", "postponed"]) @map("kanban_columns")
  position      Int      @default(0)
  archivedAt  DateTime? @map("archived_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
  @@index([ownerId])
  @@map("lists")
}

// US-TA-01..04 — Tâches. parentTaskId : sous-tâches (hiérarchie Sprint 5).
model Task {
  id               String    @id @default(uuid()) @db.Uuid
  listId           String    @map("list_id") @db.Uuid
  parentTaskId     String?   @map("parent_task_id") @db.Uuid
  ownerId          String    @map("owner_id") @db.Uuid
  // US-TA-07 — assignation (prep partage : dropdown membres + notif aux
  // sprints sharing/notif). SetNull si l'assigné est supprimé.
  assignedTo       String?   @map("assigned_to") @db.Uuid
  title            String    @db.VarChar(240)
  description      String?
  // 'todo' | 'doing' | 'done' | 'postponed' | 'canceled'
  status           String    @default("todo") @db.VarChar(16)
  // 0=P0 critique … 3=P3 bas
  priority         Int       @default(2) @db.SmallInt
  dueAt            DateTime? @map("due_at")
  startAt          DateTime? @map("start_at")
  estimatedMinutes Int?      @map("estimated_minutes")
  position         Int       @default(0)
  completedAt      DateTime? @map("completed_at")
  archivedAt       DateTime? @map("archived_at")
  // US-RE-01..04 — récurrence. Une tâche "modèle" porte recurrenceRuleId
  // (occurrenceDate null) ; chaque occurrence générée a (recurrenceRuleId,
  // occurrenceDate) unique. recurrenceException : occurrence éditée à la
  // main, le générateur ne la régénère/écrase plus.
  recurrenceRuleId    String?   @map("recurrence_rule_id") @db.Uuid
  occurrenceDate      DateTime? @map("occurrence_date")
  recurrenceException Boolean   @default(false) @map("recurrence_exception")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  children       Task[]          @relation("Subtasks")
  parent         Task?           @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  list           List            @relation(fields: [listId], references: [id], onDelete: Cascade)
  owner          User            @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  assignee       User?           @relation("TaskAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  taskTags       TaskTag[]
  recurrenceRule RecurrenceRule? @relation(fields: [recurrenceRuleId], references: [id], onDelete: SetNull)
  notifications  Notification[]
  syncEvents     SyncEvent[]

  @@unique([recurrenceRuleId, occurrenceDate])
  @@index([listId])
  @@index([ownerId, status])
  @@index([ownerId, dueAt])
  @@index([parentTaskId])
  @@index([assignedTo])
  // US-TA-08 — recherche full-text trigram (accélère ILIKE).
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("tasks")
}

// US-TG-01 — Tags par utilisateur (nom + couleur). Unicité du nom par owner.
model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  ownerId   String   @map("owner_id") @db.Uuid
  name      String   @db.VarChar(60)
  color     String?  @db.VarChar(7)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  taskTags TaskTag[]

  @@unique([ownerId, name])
  @@index([ownerId])
  @@map("tags")
}

// US-TG-02 — Association M2M tâche ↔ tag (suppression en cascade des deux côtés).
model TaskTag {
  taskId String @map("task_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
  @@map("task_tags")
}

// US-RE-01 — Règle de récurrence RFC 5545 (RRULE). endAt = borne dure
// éventuelle (en plus d'un UNTIL/COUNT dans la RRULE).
model RecurrenceRule {
  id        String    @id @default(uuid()) @db.Uuid
  ownerId   String    @map("owner_id") @db.Uuid
  rrule     String
  endAt     DateTime? @map("end_at")
  createdAt DateTime  @default(now()) @map("created_at")

  owner User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([ownerId])
  @@map("recurrence_rules")
}

// US-NO-* — Notification (in-app + canaux). payload = contenu sérialisé.
model Notification {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  taskId       String?   @map("task_id") @db.Uuid
  // 'reminder' | 'recurring_due' | 'share_invite' | 'comment' | 'digest' | …
  type         String    @db.VarChar(32)
  // 'web_push' | 'expo_push' | 'email' | 'in_app'
  channel      String    @db.VarChar(16)
  payload      Json
  scheduledFor DateTime  @map("scheduled_for")
  sentAt       DateTime? @map("sent_at")
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Idempotence des rappels : un seul (task, type, scheduledFor) par tâche.
  @@unique([taskId, type, scheduledFor])
  @@index([userId, readAt])
  @@index([scheduledFor, sentAt])
  @@map("notifications")
}

// US-NO-01 — Abonnement Web Push (VAPID).
model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String    @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// US-SY-01 — Agenda externe connecté (Google d'abord ; Microsoft/Apple aux
// sprints 13/14 réutiliseront ce modèle via `provider`). Les tokens OAuth
// vivent déjà chiffrés dans `accounts` (Better Auth, US-AU-05) : on ne les
// duplique pas, on s'y réfère par `provider`. Ce modèle absorbe l'état de
// sync (`sync_states` du MLD) : jeton delta + canal watch sont 1:1 avec
// l'agenda connecté — une table séparée serait de la sur-normalisation.
model CalendarAccount {
  id                String @id @default(uuid()) @db.Uuid
  userId            String @map("user_id") @db.Uuid
  provider          String @default("google") @db.VarChar(16)
  // Compte chez le provider (sub/e-mail Google) + agenda ciblé.
  providerAccountId String @map("provider_account_id")
  calendarId        String @default("primary") @map("calendar_id")

  // US-SY-03 — état de sync : jeton incrémental Google + canal push watch.
  syncToken       String?   @map("sync_token")
  watchChannelId  String?   @map("watch_channel_id")
  watchResourceId String?   @map("watch_resource_id")
  watchExpiresAt  DateTime? @map("watch_expires_at")
  lastSyncedAt    DateTime? @map("last_synced_at")
  // Déconnexion = soft : on conserve le mapping pour ne pas réémettre
  // d'événements si l'utilisateur reconnecte.
  disabledAt      DateTime? @map("disabled_at")

  // US-SY-07 — CalDAV (provider="caldav"). Pas d'OAuth : auth Basic avec
  // app-password CHIFFRÉ au repos (TokenCipher, jamais en clair). `kind` =
  // icloud|nextcloud|samsung|generic (détecté depuis l'URL, informatif).
  // Pour les providers OAuth ces colonnes restent nulles.
  caldavUrl      String? @map("caldav_url")
  caldavUsername String? @map("caldav_username")
  caldavPassword String? @map("caldav_password")
  caldavKind     String? @map("caldav_kind") @db.VarChar(16)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncEvents SyncEvent[]

  @@unique([userId, provider, calendarId])
  @@index([userId])
  @@map("calendar_accounts")
}

// US-SY-02/03 — Mapping bidirectionnel tâche ↔ événement Google. `pushedHash`
// = empreinte du dernier état poussé : un re-push qui ne change rien est un
// no-op (idempotent). Soft-delete (`deletedAt`) plutôt que suppression : on
// garde la trace pour ne pas recréer un event sur une tâche redevenue
// éligible par erreur, et pour réconcilier les suppressions venues de Google.
model SyncEvent {
  id                String @id @default(uuid()) @db.Uuid
  calendarAccountId String @map("calendar_account_id") @db.Uuid
  taskId            String @map("task_id") @db.Uuid
  googleEventId     String @map("google_event_id")

  etag       String?
  pushedHash String?   @map("pushed_hash")
  deletedAt  DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  calendarAccount CalendarAccount @relation(fields: [calendarAccountId], references: [id], onDelete: Cascade)
  task            Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([calendarAccountId, taskId])
  @@unique([calendarAccountId, googleEventId])
  @@index([taskId])
  @@map("sync_events")
}
